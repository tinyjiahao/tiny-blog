// ==========================================================
// Custom styles: 手动深色主题切换
// NexT 原生 darkmode 只跟随系统 (@media prefers-color-scheme)，
// 这里通过 html.theme-dark 类额外提供手动覆盖，
// 由 body-end.njk 中的按钮 + localStorage 控制。
// 配色取自 NexT 内置 dark 变量，保持与系统深色一致。
// ==========================================================

html.theme-dark {
  // 覆盖 NexT CSS 变量：菜单 hover/active 背景（默认 #f5f5f5，深色下改为暗色）
  --menu-item-bg-color: #444;

  // 全局背景与文字
  body {
    background: #222 !important;
    color: #ccc !important;
  }

  // 内容区背景（文章块、侧边栏、页眉等卡片）
  .header,
  .main-inner,
  .post-block,
  .sidebar,
  .sidebar-inner,
  .site-overview,
  .comments,
  .pagination,
  .sub-menu,
  .tabs-comment {
    background: #333 !important;
    color: #ccc !important;
  }

  // 文章正文文字
  .post-body {
    color: #ccc !important;

    h1, h2 {
      border-bottom-color: #555 !important;
    }
    h3 {
      border-bottom-color: #555 !important;
    }
    a {
      color: #ccc !important;
    }
  }

  // 标题、作者、元信息
  .post-title,
  .site-author-name,
  .site-state-item a,
  .post-meta,
  .post-meta-item {
    color: #ccc !important;
  }

  // 顶部菜单
  .menu-item a {
    color: #ccc !important;
  }

  // 导航选中项：覆盖 Gemini 主题的浅色高亮背景
  .menu-item-active a,
  .menu-item a.active,
  .menu-item.active a {
    background: #444 !important;
    color: #eee !important;
    border-color: #555 !important;
  }

  // 阅读全文 / 按钮
  .btn,
  a.btn {
    background: #444 !important;
    color: #ccc !important;
    border-color: #666 !important;

    &:hover {
      background: #555 !important;
      color: #eee !important;
      border-color: #888 !important;
    }
  }

  // 侧边栏站点统计链接 hover
  .site-state-item:hover a,
  .menu-item a:hover {
    color: #eee !important;
  }

  // 代码块（与 NexT dark highlight 一致）
  .highlight,
  pre {
    background: #282828 !important;
    color: #ccc !important;

    .gutter {
      background: #363636 !important;
    }
  }

  // 表格（与 NexT dark 表格配色一致）
  table {
    tbody tr:nth-of-type(odd) {
      background: #282828 !important;
    }
    tbody tr:hover {
      background: #363636 !important;
    }
  }

  // 引用块
  blockquote {
    color: #999 !important;
    border-left-color: #555 !important;
  }

  // 行内代码：GitHub Dark 风格
  :not(pre) > code {
    background: #2d333b !important;
    color: #adbac7 !important;
    border-radius: 4px !important;
    padding: 2px 6px !important;
    border: 1px solid #444c56 !important;
  }

  // 卡片式区块边框
  .back-to-top,
  .posts-collapse .post-meta,
  .post-eof {
    background: #333 !important;
  }
}

// ==========================================================
// 返回顶部按钮：移到右下角
// ==========================================================
.back-to-top {
  left: auto !important;
  right: 30px;
}

// ==========================================================
// 主题切换按钮样式
// ==========================================================
.theme-toggle {
  position: fixed;
  top: 16px;
  right: 16px;
  z-index: 1001;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: none;
  background: #eee;
  color: #222;
  font-size: 18px;
  cursor: pointer;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  transition: background 0.3s, color 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

html.theme-dark .theme-toggle {
  background: #555;
  color: #ccc;
}

// ==========================================================
// 文章末尾阅读次数
// ==========================================================
.post-view-count {
  margin-top: 2rem;
  color: #999;
  font-size: 0.875em;
  text-align: center;

  .fa-eye {
    margin-right: 0.35em;
  }
}

.post-view-count.is-error {
  color: #aaa;
}

html.theme-dark .post-view-count {
  color: #999 !important;
}
